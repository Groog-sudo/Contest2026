APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contest2026
# 테스트/로컬 fallback 용도입니다. APP_DATABASE_URL이 비어 있을 때만 사용됩니다.
APP_DB_PATH=./data/mentoring.sqlite3
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_LOCAL_DIR=./data/object_storage
OBJECT_STORAGE_PUBLIC_BASE_URL=
STT_PROVIDER_NAME=mock
STT_PROVIDER_API_KEY=
TTS_PROVIDER_NAME=mock
TTS_PROVIDER_API_KEY=
QUEUE_AUTO_PROCESS=true
QUEUE_MAX_ATTEMPTS=3
CALL_PROVIDER_NAME=mock
CALL_PROVIDER_API_KEY=
OUTBOUND_CALL_FROM_NUMBER=
# JSON 형식의 리스트로 여러 오리진을 허용합니다 (예: ["http://localhost:5173", "http://192.168.0.163:5173"])
FRONTEND_ORIGINS=["http://localhost:5173"]

